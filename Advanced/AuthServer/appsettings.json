{
    "ConnectionStrings": {
        "DefaultConnection": "DataSource=authserver.db;Cache=Shared"
    },
    "Oidc": {

        "Authority": "https://localhost:7215",
        "Certificates": {
            "Path": "oidc.pfx",
            "Password": "password"
        },
        "WebAppClient": {
            "ClientId": "webapp_client",
            "ClientSecret": "webapp_secret",
            "DisplayName": "Webapp client"
        },
        "ApiAClient": {
            "ClientId": "apia_client",
            "ClientSecret": "apia_secret",
            "DisplayName": "ApiA client"
        },
        "ApiAScope": {
            "Name": "api_a",
            "Resource": "api_a_resource"
        },
        "ApiBScope": {
            "Name": "api_b",
            "Resource": "api_b_resource"
        },

        "TokenExchange": {
            "AllowedPresenters": {
                "webapp_client":["apia_client"]
            } 
        }

    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}